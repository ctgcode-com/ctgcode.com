---
/**
 * Router — la entrada del sitio: "la carta de navegación".
 *
 * Narrativa de marca: acabas de arribar de noche al puerto de Cartagena. Sobre
 * una carta náutica, una brújula hecha con el sol del logo (sus 8 rayos son la
 * rosa de los vientos) busca tu rumbo; al detectar el idioma del navegador, la
 * aguja se clava en tu orilla: «es» al oeste (cálida) o «en» al este (fría).
 * Las dos orillas quedan siempre a un clic por si el viento tarda.
 *
 * Estilos en styles/router.css.
 */
import Layout from "../../layouts/Layout.astro";
import { locales } from "../../data/i18n";
import "../../styles/router.css";

const t = locales.es.router;
const es = locales.es.router;
const en = locales.en.router;
---

<Layout title="CTG Code" description={t.lead} pageName="home">
  <main class="rt-scene" data-tone="night">
    <a class="brand-mono rt-brand" href="/">
      <span class="brace">&#123;</span> ctgcode <span class="brace">&#125;</span
      >
    </a>

    <div class="rt-layout">
      <!-- La bitácora -->
      <section class="rt-panel">
        <p class="eyebrow" data-rt="eyebrow">{t.eyebrow}</p>
        <h1 data-rt="title">{t.title}</h1>
        <p class="rt-lead" data-rt="lead">{t.lead}</p>

        <p class="rt-status" data-rt="status" aria-live="polite">
          {t.detecting}
        </p>

        <div class="rt-shores">
          <a
            class="rt-shore rt-shore--es"
            href="/es/"
            data-rt-shore="es"
            draggable="false"
          >
            <span class="rt-shore-code">es · 10.42° N</span>
            <strong class="rt-shore-name">Español</strong>
            <span class="rt-shore-note">la orilla del Caribe</span>
          </a>

          <a
            class="rt-shore rt-shore--en"
            href="/en/"
            data-rt-shore="en"
            hreflang="en"
            lang="en"
            draggable="false"
          >
            <span class="rt-shore-code">en · high seas</span>
            <strong class="rt-shore-name">English</strong>
            <span class="rt-shore-note">the other shore</span>
          </a>
        </div>
      </section>

      <!-- La brújula: el sol del logo como rosa de los vientos -->
      <div class="rt-compass" data-rt="compass" aria-hidden="true">
        <svg viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg">
          <!-- anillo exterior y puntas del sol girando a contracorriente -->
          <circle
            class="rt-ring"
            cx="100"
            cy="100"
            r="92"
            fill="none"
            stroke-width="1"></circle>
          <g class="rt-points">
            <path d="M100 2 L104 9 L96 9 Z" transform="rotate(22.5 100 100)"
            ></path>
            <path d="M100 2 L104 9 L96 9 Z" transform="rotate(67.5 100 100)"
            ></path>
            <path d="M100 2 L104 9 L96 9 Z" transform="rotate(112.5 100 100)"
            ></path>
            <path d="M100 2 L104 9 L96 9 Z" transform="rotate(157.5 100 100)"
            ></path>
            <path d="M100 2 L104 9 L96 9 Z" transform="rotate(202.5 100 100)"
            ></path>
            <path d="M100 2 L104 9 L96 9 Z" transform="rotate(247.5 100 100)"
            ></path>
            <path d="M100 2 L104 9 L96 9 Z" transform="rotate(292.5 100 100)"
            ></path>
            <path d="M100 2 L104 9 L96 9 Z" transform="rotate(337.5 100 100)"
            ></path>
          </g>

          <!-- la rosa: los 8 rayos del sol del logo -->
          <g class="rt-rose">
            <path d="M100 50 L107 66 L93 66 Z"></path>
            <path d="M100 50 L107 66 L93 66 Z" transform="rotate(45 100 100)"
            ></path>
            <path d="M100 50 L107 66 L93 66 Z" transform="rotate(90 100 100)"
            ></path>
            <path d="M100 50 L107 66 L93 66 Z" transform="rotate(135 100 100)"
            ></path>
            <path d="M100 50 L107 66 L93 66 Z" transform="rotate(180 100 100)"
            ></path>
            <path d="M100 50 L107 66 L93 66 Z" transform="rotate(225 100 100)"
            ></path>
            <path d="M100 50 L107 66 L93 66 Z" transform="rotate(270 100 100)"
            ></path>
            <path d="M100 50 L107 66 L93 66 Z" transform="rotate(315 100 100)"
            ></path>
          </g>
          <circle
            class="rt-hub"
            cx="100"
            cy="100"
            r="22"
            fill="none"
            stroke-width="8"></circle>

          <!-- la aguja -->
          <g class="rt-needle">
            <path class="rt-needle-n" d="M100 24 L105 100 L95 100 Z"></path>
            <path class="rt-needle-s" d="M100 176 L105 100 L95 100 Z"></path>
          </g>
        </svg>

        <span class="rt-compass-label rt-compass-label--es">es</span>
        <span class="rt-compass-label rt-compass-label--en">en</span>
      </div>
    </div>
  </main>

  <script is:inline define:vars={{ es, en }}>
    (function () {
      const browserLang = (navigator.language || "")
        .split(",")[0]
        .split("-")[0]
        .toLowerCase();
      const isEn = browserLang === "en";
      const lang = isEn ? "en" : "es";
      const dest = `/${lang}/`;
      const t = isEn ? en : es;

      // La bitácora habla el idioma del navegante.
      if (isEn) {
        document.documentElement.lang = "en";
        for (const key of ["eyebrow", "title", "lead"]) {
          const el = document.querySelector(`[data-rt="${key}"]`);
          if (el) el.textContent = en[key];
        }
        const status = document.querySelector('[data-rt="status"]');
        if (status) status.textContent = en.detecting;
      }

      // La aguja busca un momento y se clava en el rumbo detectado.
      setTimeout(() => {
        const compass = document.querySelector('[data-rt="compass"]');
        const status = document.querySelector('[data-rt="status"]');
        const shore = document.querySelector(`[data-rt-shore="${lang}"]`);

        if (compass) compass.setAttribute("data-bearing", lang);
        if (status) status.textContent = t.ready + dest;
        if (shore) shore.setAttribute("data-detected", "");

        // Redirección automática
      }, 1600);

      window.location.replace(dest);
    })();
  </script>
</Layout>
