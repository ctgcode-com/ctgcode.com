---
/**
 * LangNotice — aviso de idioma disponible.
 *
 * Si el idioma del navegador difiere del de la página Y existe esa versión,
 * muestra un aviso discreto (en el idioma de destino) invitando a cambiar.
 * NO redirige solo: únicamente al pulsar el enlace. Se recuerda el descarte.
 *
 * Renderiza una tarjeta oculta por cada otro idioma disponible; el script
 * revela la que coincide con `navigator.language`. Estilos en lang-notice.css.
 */
import { locales, localizedPath, type LocaleSchema } from "../../data/i18n";
import "../../styles/lang-notice.css";

interface Props {
  lang: keyof typeof locales;
}

const { lang } = Astro.props;

const others = (Object.keys(locales) as (keyof typeof locales)[]).filter(
  (l) => l !== lang,
);
---

<div class="lang-notice" data-lang-notice>
  {
    others.map((l) => {
      const n: LocaleSchema["langNotice"] = locales[l].langNotice;
      return (
        <aside
          class="ln-card"
          data-ln-for={l}
          role="status"
          aria-label={n.message}
          lang={l}
          hidden
        >
          <span class="ln-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <circle cx="12" cy="12" r="9" />
              <path d="M3 12h18" />
              <path d="M12 3c2.5 2.4 3.8 5.6 3.8 9s-1.3 6.6-3.8 9c-2.5-2.4-3.8-5.6-3.8-9s1.3-6.6 3.8-9z" />
            </svg>
          </span>

          <p class="ln-msg">{n.message}</p>

          <a
            class="ln-action"
            href={localizedPath(l)}
            hreflang={l}
            lang={l}
            data-ln-go
          >
            {n.action}
          </a>

          <button
            class="ln-close"
            type="button"
            data-ln-dismiss
            aria-label={n.dismiss}
          >
            <span aria-hidden="true">&times;</span>
          </button>
        </aside>
      );
    })
  }
</div>

<script>
  const KEY = "ctg-lang-notice-dismissed";
  const root = document.querySelector<HTMLElement>("[data-lang-notice]");

  if (root && localStorage.getItem(KEY) !== "1") {
    const browserLang = (navigator.language || "")
      .split("-")[0]
      .toLowerCase();
    const card = root.querySelector<HTMLElement>(
      `[data-ln-for="${browserLang}"]`,
    );

    if (card) {
      const dismiss = () => localStorage.setItem(KEY, "1");

      const close = () => {
        dismiss();
        card.removeAttribute("data-open");
        card.addEventListener(
          "transitionend",
          () => {
            card.hidden = true;
          },
          { once: true },
        );
      };

      // Revelar (doble rAF para que la transición de entrada corra).
      card.hidden = false;
      requestAnimationFrame(() =>
        requestAnimationFrame(() => card.setAttribute("data-open", "")),
      );

      card
        .querySelector<HTMLButtonElement>("[data-ln-dismiss]")
        ?.addEventListener("click", close);

      // Al cambiar de idioma no hace falta volver a avisar.
      card
        .querySelector<HTMLAnchorElement>("[data-ln-go]")
        ?.addEventListener("click", dismiss);

      document.addEventListener("keydown", (e) => {
        if (e.key === "Escape" && !card.hidden) close();
      });
    }
  }
</script>
