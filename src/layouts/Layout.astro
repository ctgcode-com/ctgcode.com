---
import { siteConfig } from '../data/site';
import { locales, localizedPath } from '../data/i18n';
import '../styles/global.css';

import '@fontsource-variable/plus-jakarta-sans/index.css';
import '@fontsource-variable/inter/index.css';
import '@fontsource-variable/jetbrains-mono/index.css';

interface Props {
  title: string;
  description: string;
  pageName: string;
  lang?: keyof typeof locales;
}

// El idioma llega por prop (no por params): así funciona igual en la raíz (es)
// que en /en, sin depender de un segmento dinámico de ruta.
const { title, description, pageName, lang = 'es' } = Astro.props;

const googleAdsId = 'AW-18316357590';

const siteUrl = siteConfig.url;
const subpath = pageName === 'home' ? '' : pageName;
const canonicalUrl = `${siteUrl}${localizedPath(lang, subpath)}`;
const ogImageUrl = `${siteUrl}/images/og/${lang}/${pageName}.png`;

// hreflang: cada idioma es una URL real; se lo decimos a Google explícitamente.
const langCodes = Object.keys(locales) as (keyof typeof locales)[];
const alternates = langCodes.map((l) => ({
  hreflang: l === 'es' ? 'es-CO' : l,
  href: `${siteUrl}${localizedPath(l, subpath)}`,
}));
const ogLocale = lang === 'es' ? 'es_CO' : 'en_US';
---

<!doctype html>
<html lang={lang}>
  <head>
    <!-- 1. Metadatos Base -->
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Alternativas por idioma (hreflang) para SEO multiidioma -->
    {alternates.map((alt) => (
      <link rel="alternate" hreflang={alt.hreflang} href={alt.href} />
    ))}
    <link rel="alternate" hreflang="x-default" href={`${siteUrl}${localizedPath('es', subpath)}`} />

    <!-- 2. SEO General y Rastreo -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content={siteConfig.author} />
    <meta name="robots" content="index, follow" />
    <link rel="sitemap" href="/sitemap-index.xml" />

    <!-- 3. UX / UI Metadatos -->
    <meta name="theme-color" content="#0a1c2b" />

    <!-- 4. Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:locale" content={ogLocale} />

    <!-- 5. Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonicalUrl} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- Conexión con Google Ads (Google Tag) -->
    {googleAdsId && (
      <>
        <script is:inline type="text/partytown" async src={`https://www.googletagmanager.com/gtag/js?id=${googleAdsId}`}></script>
        <script is:inline type="text/partytown" define:vars={{ googleAdsId }}>
          window.dataLayer = window.dataLayer || [];
          window.gtag = function(){window.dataLayer.push(arguments);}
          gtag('js', new Date());
          gtag('config', googleAdsId);
        </script>
      </>
    )}
  </head>
  <body>
    <slot />
  </body>
</html>

<style>
  html,
  body {
    margin: 0;
    width: 100%;
    height: 100%;
  }
</style>
